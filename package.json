		"pg": "^8.22.0",
		"pino": "^10.3.1",
		"postprocessing": "^6.36.0",
		"radix-ui": "^1.4.3",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-hook-form": "^7.76.0",
		"resend": "^6.12.3",
		"satori": "^0.26.0",
		"shadcn": "^4.7.0",
		"sileo": "^0.1.5",
		"tailwind-merge": "^3.6.0",
		"tailwindcss": "^4.2.1",
		"three": "^0.167.1",
		"tw-animate-css": "^1.4.0",
		"vite-tsconfig-paths": "^5.1.4",
		"ws": "^8.21.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@tanstack/devtools-vite": "^0.6.0",
		"@trigger.dev/build": "4.4.6",
		"@types/mdx": "^2.0.14",
		"@types/node": "^22.19.15",
		"@types/nodemailer": "^8.0.1",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.2.0",
		"jsdom": "^27.4.0",
		"knip": "^6.14.1",
		"lefthook": "^2.1.8",
		"pino-pretty": "^13.1.3",
		"portless": "^0.13.0",
		"prisma": "^7.8.0",
		"react-email": "^6.2.0",
		"trigger.dev": "4.4.6",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^3.2.4"
	},
	"overrides": {
		"@better-auth/core": "1.6.13"
	},
