{
	"name": "pstrack",
	"version": "3.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "PORTLESS_NGROK=1 portless",
		"dev:app": "vite dev --host 127.0.0.1 --port=${PORT:-3001}",
		"dev:trigger": "trigger dev",
		"deploy:trigger-prod": "trigger deploy",
		"dev:email": "bunx react-email dev --dir src/emails --port 3001",
		"build": "prisma generate && vite build",
		"preview": "vite preview",
		"prepare": "test -d .git && lefthook install || true",
		"postinstall": "prisma generate",
		"db:generate": "prisma generate",
		"db:format": "prisma format",
		"db:migrate": "prisma migrate dev",
		"db:migrate:deploy": "prisma migrate deploy",
		"db:migrate:status": "prisma migrate status",
		"db:pull": "prisma db pull",
		"db:push": "prisma db push",
		"db:seed": "bun run prisma/seed.ts",
		"db:seed-problems": "bun run prisma/seed-problems.ts",
		"db:seed-groups": "bun run prisma/seed-groups.ts",
		"db:seed-daily-problems": "bun run prisma/seed-daily-problems.ts",
		"db:reset": "prisma migrate reset",
		"db:studio": "bunx db-studio@latest --database-url \"$DATABASE_URL\"",
		"prisma:generate": "prisma generate",
		"test": "vitest run",
		"test:stress": "vitest run --project integration stress --no-file-parallelism",
		"format": "biome check --write --unsafe .",
		"check": "bun run biome check .",
		"knip": "knip",
		"typecheck": "prisma generate && tsc --noEmit",
		"env:sync:prod": "bun run scripts/sync-coolify.ts",
		"env:sync:trigger": "bun run scripts/sync-trigger.ts",
		"env:sync:gh": "bun run scripts/sync-gh.ts",
		"env:sync:stage": "bun run scripts/sync-vercel.ts",
		"env:sync:stage:dry-run": "bun run scripts/sync-vercel.ts --dry-run",
		"smoke:stage": "bun run scripts/smoke-stage.ts",
		"jobs:reconcile-mark-missed": "bun run scripts/reconcile-mark-missed.ts",
		"points:reconcile": "bun run scripts/reconcile-points.ts"
	},
	"portless": {
		"name": "pstrack",
		"script": "dev:app"
	},
	"dependencies": {
		"@axiomhq/js": "^1.8.0",
		"@better-auth/infra": "0.2.14",
		"@elysiajs/eden": "^1.4.9",
		"@elysiajs/openapi": "^1.4.15",
		"@fontsource-variable/geist": "^5.2.9",
		"@fontsource/geist": "^5.2.9",
		"@hookform/resolvers": "^5.4.0",
		"@mdx-js/react": "^3.1.1",
		"@mdx-js/rollup": "^3.1.1",
		"@neondatabase/serverless": "^1.1.0",
		"@polar-sh/better-auth": "^1.8.4",
		"@prisma/adapter-neon": "^7.8.0",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@react-email/components": "^1.0.12",
		"@react-email/render": "^2.0.8",
		"@react-three/fiber": "^9.3.0",
		"@react-three/postprocessing": "^3.0.4",
		"@resvg/resvg-js": "^2.6.2",
		"@sentry/node": "^10.57.0",
		"@sentry/react": "^10.53.1",
		"@t3-oss/env-core": "^0.13.11",
		"@tabler/icons-react": "^3.44.0",
		"@tailwindcss/typography": "^0.5.20",
		"@tailwindcss/vite": "^4.2.1",
		"@tanstack/react-devtools": "^0.10.0",
		"@tanstack/react-query": "^5.100.14",
		"@tanstack/react-query-devtools": "^5.100.14",
		"@tanstack/react-router": "^1.167.4",
		"@tanstack/react-router-devtools": "^1.166.9",
		"@tanstack/react-start": "^1.166.15",
		"@tanstack/react-virtual": "^3.13.26",
		"@trigger.dev/sdk": "4.4.6",
		"@types/canvas-confetti": "^1.9.0",
		"@upstash/redis": "^1.38.0",
		"better-auth": "1.6.13",
		"canvas-confetti": "^1.9.4",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"date-fns": "^4.2.1",
		"dotenv": "^17.4.2",
		"elysia": "^1.4.28",
		"hashvatar": "^0.1.2",
		"lucide-react": "^1.16.0",
		"motion": "^12.40.0",
		"nitro": "^3.0.260610-beta",
