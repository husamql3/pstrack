{
	"name": "pstrack",
	"version": "3.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "portless",
		"dev:app": "vite dev --host 127.0.0.1 --port=${PORT:-3001}",
		"dev:trigger": "npx trigger.dev@latest dev",
		"dev:email": "bunx react-email dev --dir src/emails --port 3001",
		"build": "prisma generate && vite build",
		"preview": "vite preview",
		"prepare": "test -d .git && lefthook install || true",
		"postinstall": "prisma generate",
		"db:generate": "prisma generate",
		"db:format": "prisma format",
		"db:migrate": "prisma migrate dev",
		"db:migrate:deploy": "prisma migrate deploy",
		"db:migrate:status": "prisma migrate status",
		"db:pull": "prisma db pull",
		"db:push": "prisma db push",
		"db:seed": "bun run prisma/seed.ts",
		"db:seed-problems": "bun run prisma/seed-problems.ts",
		"db:seed-groups": "bun run prisma/seed-groups.ts",
		"db:seed-daily-problems": "bun run prisma/seed-daily-problems.ts",
		"db:reset": "prisma migrate reset",
		"db:studio": "bunx db-studio@latest --env .env",
		"prisma:generate": "prisma generate",
		"test": "vitest run",
		"format": "biome check --write .",
		"check": "bun run biome check .",
		"knip": "knip",
		"typecheck": "prisma generate && tsc --noEmit",
		"env:sync": "bun run scripts/sync-env.ts"
	},
	"portless": {
		"name": "pstrack",
		"script": "dev:app"
	},
	"dependencies": {
		"@elysiajs/eden": "^1.4.9",
		"@elysiajs/openapi": "^1.4.15",
		"@fontsource-variable/geist": "^5.2.9",
		"@hookform/resolvers": "^5.4.0",
		"@neondatabase/serverless": "^1.1.0",
		"@polar-sh/better-auth": "^1.8.4",
		"@prisma/adapter-neon": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@react-email/components": "^1.0.12",
		"@react-email/render": "^2.0.8",
		"@sentry/bun": "^10.53.1",
		"@sentry/react": "^10.53.1",
		"@t3-oss/env-core": "^0.13.11",
		"@tabler/icons-react": "^3.44.0",
		"@tailwindcss/vite": "^4.2.1",
		"@tanstack/react-devtools": "^0.10.0",
		"@tanstack/react-query": "^5.100.14",
		"@tanstack/react-query-devtools": "^5.100.14",
		"@tanstack/react-router": "^1.167.4",
		"@tanstack/react-router-devtools": "^1.166.9",
		"@tanstack/react-router-ssr-query": "^1.166.9",
		"@tanstack/react-start": "^1.166.15",
		"@tanstack/react-table": "^8.21.3",
		"@tanstack/react-virtual": "^3.13.26",
		"@tanstack/router-plugin": "^1.166.13",
		"@trigger.dev/sdk": "4.4.6",
		"@types/canvas-confetti": "^1.9.0",
		"better-auth": "^1.6.11",
		"canvas-confetti": "^1.9.4",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"dotenv": "^17.4.2",
		"elysia": "^1.4.28",
		"hashvatar": "^0.1.2",
		"lucide-react": "^1.16.0",
		"next-themes": "^0.4.6",
		"nitro": "latest",
		"radix-ui": "^1.4.3",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-hook-form": "^7.76.0",
		"resend": "^6.12.3",
		"shadcn": "^4.7.0",
		"sileo": "^0.1.5",
		"tailwind-merge": "^3.6.0",
		"tailwindcss": "^4.2.1",
		"tw-animate-css": "^1.4.0",
		"vite-tsconfig-paths": "^5.1.4",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@react-email/ui": "6.2.0",
		"@tanstack/devtools-vite": "^0.6.0",
		"@tanstack/eslint-plugin-query": "^5.100.14",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.2",
		"@trigger.dev/build": "4.4.6",
		"@types/node": "^22.19.15",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.2.0",
		"jsdom": "^27.4.0",
		"knip": "^6.14.1",
		"lefthook": "^2.1.8",
		"portless": "^0.13.0",
		"prisma": "^7.8.0",
		"react-email": "^6.2.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^3.2.4",
		"web-vitals": "^5.1.0"
	},
	"engines": {
		"node": ">=22.0.0",
		"bun": ">=1.2.2"
	}
}
