		"@types/bun": "^1.3.14",
		"@types/node": "^24",
		"@types/nodemailer": "^8.0.1",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@types/ws": "^8.18.1",
		"@vitejs/plugin-react": "^5.2.0",
		"jsdom": "^27.4.0",
		"knip": "^6.27.0",
