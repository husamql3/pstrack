{
	"name": "api",
	"type": "module",
	"scripts": {
		"dev": "NODE_ENV=development tsx src/index.ts",
		"build": "NODE_ENV=production tsdown",
		"start": "node dist/index.mjs",
		"db:dev": "prisma migrate dev --name init",
		"db:reset": "prisma migrate reset --force",
		"db:gen": "prisma generate",
		"db:studio": "bunx db-studio@latest",
		"db:prod": "prisma migrate deploy"
	},
	"dependencies": {
		"@hono/sentry": "^1.2.2",
		"@hono/zod-openapi": "^1.2.1",
		"@hono/zod-validator": "^0.7.6",
		"@neondatabase/serverless": "^1.0.2",
		"@prisma/adapter-pg": "^7.4.0",
		"@prisma/client": "^7.4.0",
		"@prisma/client-runtime-utils": "^7.4.0",
		"@prisma/extension-accelerate": "^3.0.1",
		"@supabase/supabase-js": "^2.95.3",
		"@t3-oss/env-core": "^0.13.10",
		"@upstash/redis": "^1.36.2",
		"better-auth": "^1.4.18",
		"dotenv": "^17.3.1",
		"hono": "^4.11.8",
		"pg": "^8.18.0",
		"prisma": "^7.4.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@hono/node-server": "^1.19.9",
		"@types/bun": "^1.3.7",
		"@types/node": "^25.1.0",
		"tsdown": "^0.20.3",
		"tsx": "^4.21.0",
		"typescript": "5.9.2"
	}
}
